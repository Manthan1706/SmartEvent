@model IEnumerable<SmartEvent.Web.Models.Event>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@{
    ViewData["Title"] = "Browse Events";
}

<style>

    body {
        background: #f4f6fb;
    }

    /* Page Title */
    .page-title {
        font-weight: 700;
        font-size: 28px;
        margin-bottom: 30px;
    }

    /* Grid Layout */
    .event-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(360px,1fr));
        gap: 24px;
    }

    /* Event Card */
    .event-card {
        background: white;
        border-radius: 14px;
        padding: 22px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        transition: .25s;
    }

        .event-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 28px rgba(0,0,0,0.10);
        }

    /* Title */
    .event-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    /* Meta Info */
    .event-meta {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    /* Capacity */
    .capacity {
        font-size: 14px;
        margin-top: 6px;
        color: #6b7280;
    }

    /* Price */
    .event-price {
        font-size: 18px;
        font-weight: 700;
        color: #16a34a;
        margin-top: 10px;
    }

    /* Buttons */
    .event-actions {
        margin-top: 18px;
    }

        .event-actions a {
            padding: 7px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            margin-right: 8px;
            transition: .2s;
        }

    /* Details */
    .btn-details {
        background: #0ea5e9;
        color: white;
    }

        .btn-details:hover {
            box-shadow: 0 5px 12px rgba(14,165,233,.35);
        }

    /* Book */
    .btn-book {
        background: #16a34a;
        color: white;
    }

        .btn-book:hover {
            box-shadow: 0 5px 12px rgba(22,163,74,.35);
        }



    /* HEADER LAYOUT */

    .search-wrapper {
        gap: 10px;
    }

    /* SEARCH INPUT */

    .search-input {
        width: 260px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        padding: 10px 12px;
        transition: 0.2s;
    }

    /* DATE INPUT */

    .date-input {
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        padding: 10px;
        width: 170px;
    }

        /* HOVER EFFECT */

        .search-input:focus,
        .date-input:focus {
            border-color: #0ea5e9;
            box-shadow: 0 0 0 2px rgba(14,165,233,.15);
        }

</style>


