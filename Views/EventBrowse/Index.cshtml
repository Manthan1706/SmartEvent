<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

    <!-- LEFT : TITLE -->
    <h2 class="page-title m-0">
        Browse Events
    </h2>

    <!-- RIGHT : SEARCH + DATE -->
    <div class="d-flex align-items-center gap-2 search-wrapper">

        <input type="text"
               id="searchInput"
               placeholder="Search event or venue..."
               class="form-control search-input" />

        <input type="date"
               id="dateFilter"
               class="form-control date-input" />

    </div>

</div>


<!-- EVENTS -->


<div class="event-grid">

    @foreach (var item in Model)
    {

        <div class="event-card"
             data-title="@item.Title.ToLower()"
             data-venue="@item.Venue.ToLower()"
             data-date="@item.EventDate.ToString("yyyy-MM-dd")">

            <div class="event-title">
                @item.Title
            </div>

            <div class="event-meta">
                📅 @item.EventDate.ToString("dd MMM yyyy • hh:mm tt")
            </div>

            <div class="event-meta">
                📍 @item.Venue
            </div>

            <div class="capacity">
                Seats Available: <b>@item.Capacity</b>
            </div>

            <div class="event-price">
                ₹@item.Price
            </div>

            <div class="event-actions">

                <a asp-controller="EventBrowse"
                   asp-action="Details"
                   asp-route-id="@item.EventId"
                   class="btn-details">
                    Details
                </a>

                <a asp-controller="Booking"
                   asp-action="Create"
                   asp-route-eventId="@item.EventId"
                   class="btn-book">
                    Book Ticket
                </a>

            </div>

        </div>

    }

</div>



<script>

    /* ELEMENTS */

    const searchInput = document.getElementById("searchInput");
    const dateFilter = document.getElementById("dateFilter");
    const cards = document.querySelectorAll(".event-card");

    /* FILTER FUNCTION */

    function filterEvents(){

        let search = searchInput.value.toLowerCase();
        let date = dateFilter.value;

        cards.forEach(card => {

            let title = card.dataset.title;
            let venue = card.dataset.venue;
            let eventDate = card.dataset.date;

            let matchSearch =
                title.includes(search) ||
                venue.includes(search);

            let matchDate =
                !date || eventDate === date;

            if(matchSearch && matchDate){
                card.style.display = "block";
            }else{
                card.style.display = "none";
            }

        });
    }

    /* EVENTS */

    searchInput.addEventListener("keyup", filterEvents);
    dateFilter.addEventListener("change", filterEvents);

</script>