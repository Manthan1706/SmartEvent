@model IEnumerable<SmartEvent.Web.Models.Event>

@{
    ViewData["Title"] = "My Events";
}

<style>

    body {
        background: #f4f6fb;
    }

    /* Page Title */
    .page-title {
        font-weight: 700;
        margin-bottom: 25px;
    }

    /* Card */
    .table-card {
        background: white;
        border-radius: 14px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    /* Table */
    .table thead {
        background: #111827;
        color: white;
    }

    .table th {
        border: none;
    }

    .table td {
        vertical-align: middle;
    }

    /* Row hover animation */
    .table tbody tr {
        transition: .2s ease;
    }

        .table tbody tr:hover {
            background: #f9fafb;
            transform: scale(1.01);
        }

    /* Status badges */
    .badge-status {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
    }

    .badge-active {
        background: #16a34a;
        color: white;
    }

    .badge-pending {
        background: #facc15;
        color: black;
    }

    .badge-cancel {
        background: #ef4444;
        color: white;
    }

    /* Action buttons */
    .action-buttons {
        display: flex;
        gap: 8px;
    }

        .action-buttons a {
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 13px;
            text-decoration: none;
            transition: .2s;
        }

    .btn-edit {
        background: #6366f1;
        color: white;
    }

        .btn-edit:hover {
            box-shadow: 0 6px 16px rgba(99,102,241,.4);
        }

    .btn-details {
        background: #10b981;
        color: white;
    }

        .btn-details:hover {
            box-shadow: 0 6px 16px rgba(16,185,129,.4);
        }

    .btn-delete {
        background: #ef4444;
        color: white;
    }

        .btn-delete:hover {
            box-shadow: 0 6px 16px rgba(239,68,68,.4);
        }

</style>



<h2 class="page-title">My Events</h2>

<div class="table-card">

    <table class="table align-middle">

        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Venue</th>
                <th>Capacity</th>
                <th>Status</th>
                <th>Price</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td><b>@item.Title</b></td>

                    <td>@item.EventDate.ToString("dd MMM yyyy")</td>

                    <td>@item.Venue</td>

                    <td>@item.Capacity</td>

                    <td>

                        @if (item.Status == "Pending")
                        {
                            <span class="badge-status badge-pending">Pending</span>
                        }

                        @if (item.Status == "Active")
                        {
                            <span class="badge-status badge-active">Active</span>
                        }

                        @if (item.Status == "Cancelled")
                        {
                            <span class="badge-status badge-cancel">Cancelled</span>
                        }

                    </td>

                    <td>₹@item.Price</td>

                    <td>

                        <div class="action-buttons">

                            <a asp-action="Edit"
                               asp-route-id="@item.EventId"
                               class="btn-edit">
                                Edit
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.EventId"
                               class="btn-details">
                                Details
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.EventId"
                               class="btn-delete">
                                Delete
                            </a>

                        </div>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>








