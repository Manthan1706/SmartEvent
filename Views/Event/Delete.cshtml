@model SmartEvent.Web.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<style>

    body {
        background: #f4f6fb;
    }

    /* Page title */
    .page-title {
        font-weight: 700;
        margin-bottom: 25px;
    }

    /* Delete Card */
    .delete-card {
        background: white;
        border-radius: 14px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: .3s;
    }

        .delete-card:hover {
            transform: translateY(-4px);
        }

    /* Warning */
    .warning-box {
        background: #fff3cd;
        border-left: 4px solid #ffc107;
        padding: 12px 16px;
        margin-bottom: 20px;
        border-radius: 6px;
    }

    /* Labels */
    .detail-label {
        font-weight: 600;
        color: #6b7280;
    }

    .detail-value {
        font-weight: 500;
    }

    /* Buttons */
    .action-buttons {
        margin-top: 20px;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        transition: .2s;
    }

        .btn-delete:hover {
            box-shadow: 0 6px 16px rgba(239,68,68,.5);
        }

    .btn-cancel {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border-radius: 8px;
        text-decoration: none;
        margin-left: 10px;
    }

        .btn-cancel:hover {
            box-shadow: 0 6px 16px rgba(107,114,128,.4);
        }

</style>



<h2 class="page-title">Delete Event</h2>

<div class="row">

    <div class="col-md-7">

        <div class="delete-card">

            <div class="warning-box">

                <strong>Warning:</strong> Are you sure you want to delete this event?

            </div>


            <div class="row mb-3">

                <div class="col-4 detail-label">
                    Title
                </div>

                <div class="col-8 detail-value">
                    @Model.Title
                </div>

            </div>



            <div class="row mb-3">

                <div class="col-4 detail-label">
                    Event Date
                </div>

                <div class="col-8 detail-value">
                    @Model.EventDate.ToString("dd MMM yyyy HH:mm")
                </div>

            </div>



            <div class="row mb-3">

                <div class="col-4 detail-label">
                    Venue
                </div>

                <div class="col-8 detail-value">
                    @Model.Venue
                </div>

            </div>



            <div class="row mb-3">

                <div class="col-4 detail-label">
                    Capacity
                </div>

                <div class="col-8 detail-value">
                    @Model.Capacity
                </div>

            </div>



            <div class="row mb-3">

                <div class="col-4 detail-label">
                    Status
                </div>

                <div class="col-8 detail-value">
                    @Model.Status
                </div>

            </div>



            <form asp-action="Delete">

                <input type="hidden" asp-for="EventId" />

                <div class="action-buttons">

                    <input type="submit" value="Delete Event" class="btn-delete" />

                    <a asp-action="Index" class="btn-cancel">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>









